# === Required ===
GOOGLE_API_KEY=your-google-gemini-api-key
# Get one at https://aistudio.google.com/app/apikey

# === Database (required for auth/chat/persistence) ===
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hirelens

# === Auth (JWT) ===
SECRET_KEY=generate-a-random-256-bit-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# === CORS ===
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# === Optional: Stripe (subscriptions) ===
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PREMIUM_PRICE_ID=

# === Optional: Redis (rate limiting, session store) ===
REDIS_URL=redis://localhost:6379/0

# === Optional: OpenAI (fallback LLM if Gemini unavailable) ===
OPENAI_API_KEY=
